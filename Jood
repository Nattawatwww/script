local function GuaranteeHogyoku()
    local playerGui = player:WaitForChild("PlayerGui", 20)
    if not playerGui then return end

    local targetLabel = playerGui.MainGui.GUARANTEE.Main.Hogyoku.Frame:FindFirstChild("TextLabel1", true) 
    if not targetLabel then return end
    local targetText = "8/8 Boss Kill"
    local isClaimed = false

    local function checkAndFire()
        if not isClaimed and targetLabel.Text == targetText then
            isClaimed = true
            game:GetService("ReplicatedStorage").System.Guarantee:FireServer("Hogyoku")
			task.wait(0.1)
			ReplicatedStorage.System.Inv.Inventory:InvokeServer("Add", "Hogyoku")
        elseif targetLabel.Text ~= targetText then
            isClaimed = false
        end
    end

    targetLabel:GetPropertyChangedSignal("Text"):Connect(checkAndFire)
    checkAndFire()
end

